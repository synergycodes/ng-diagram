{
  "name": "ng-diagram-package",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "cross-env NODE_ENV=development turbo watch dev --filter=!docs --filter=!@ng-diagram-package/e2e",
    "dev:mobile": "cross-env NODE_ENV=development turbo watch dev --filter=!docs --filter=!@ng-diagram-package/e2e -- --host 0.0.0.0 --port 6011",
    "docs:dev": "cross-env NODE_ENV=development turbo watch docs:dev",
    "docs:build": "turbo run build --filter=docs",
    "lint:check": "turbo run lint:check",
    "lint:fix": "turbo run lint:fix",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "check-types": "turbo run check-types --parallel",
    "api:report": "turbo run api:report",
    "api:check": "turbo run api:check",
    "api:update": "turbo run api:update",
    "test": "turbo run test --parallel",
    "test:coverage": "turbo run test --parallel -- --coverage",
    "e2e": "turbo run e2e --filter=@ng-diagram-package/e2e",
    "e2e:ui": "pnpm --filter @ng-diagram-package/e2e e2e:ui",
    "e2e:install": "pnpm --filter @ng-diagram-package/e2e e2e:install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^10.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "stylus": "0.0.1-security"
    }
  }
}
