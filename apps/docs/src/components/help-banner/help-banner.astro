---
import { Icon } from '@astrojs/starlight/components';
import { CONTACT_URL } from '../../consts';

export type Props = {
  title: string;
  body: string;
  linkLabel?: string;
  href?: string;
};

const DEFAULT_LINK_LABEL = 'Talk to the team';

const { title, body, linkLabel = DEFAULT_LINK_LABEL, href = CONTACT_URL } = Astro.props;

const pagePath = Astro.url.pathname;
---

<aside class="help-banner">
  <div class="help-banner-icon" aria-hidden="true">
    <Icon name="comment-alt" />
  </div>
  <div class="help-banner-content">
    <p class="help-banner-title">{title}</p>
    <p class="help-banner-body">{body}</p>
    <a
      class="help-banner-link"
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      data-umami-event="help-banner-click"
      data-umami-event-page={pagePath}
    >
      {`${linkLabel} →`}
    </a>
  </div>
</aside>

<style>
  @layer starlight.core {
    .help-banner {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-top: 3rem;
      padding: 1.25rem 1.5rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      background: var(--sl-color-gray-6);
      color: var(--sl-color-gray-2);
    }

    .help-banner-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--sl-color-gray-5);
      color: var(--sl-color-text-accent);
    }

    .help-banner-icon :global(svg) {
      width: 1rem;
      height: 1rem;
    }

    .help-banner-content {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      min-width: 0;
    }

    .help-banner-title {
      margin: 0;
      font-size: var(--sl-text-base);
      font-weight: 600;
      color: var(--sl-color-white);
      line-height: 1.4;
    }

    .help-banner-body {
      margin: 0;
      font-size: var(--sl-text-sm);
      line-height: 1.6;
      color: var(--sl-color-gray-3);
    }

    .help-banner-link {
      margin-top: 0.5rem;
      font-size: var(--sl-text-sm);
      font-weight: 500;
      color: var(--sl-color-text-accent);
      text-decoration: none;
      width: fit-content;
    }

    .help-banner-link:hover {
      text-decoration: underline;
    }

    @media (max-width: 30em) {
      .help-banner {
        padding: 1rem;
        gap: 0.75rem;
      }
    }

    @media print {
      .help-banner {
        display: none;
      }
    }
  }
</style>
