{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false,
    "cache": { "enabled": false }
  },
  "projects": {
    "harness": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "harness",
      "prefix": "harness",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/harness",
            "index": "harness/index.html",
            "main": "harness/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "styles": ["harness/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [{ "type": "initial", "maximumWarning": "1MB", "maximumError": "2MB" }],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "harness:build:production" },
            "development": { "buildTarget": "harness:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
