{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc/e2e",
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "target": "ES2022",
    "module": "ES2022",
    "types": ["node"]
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "harness/api.ts"]
}
