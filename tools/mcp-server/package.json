{
  "name": "@ng-diagram/mcp-server",
  "version": "0.7.0",
  "description": "MCP server for ng-diagram documentation search",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ng-diagram-mcp": "dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "prebuild": "node scripts/clean.js",
    "build": "tsc && node scripts/bundle-data.js",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "documentation",
    "search"
  ],
  "author": "Synergy Codes",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "gray-matter": "^4.0.3",
    "minisearch": "^7.2.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.0"
  }
}
